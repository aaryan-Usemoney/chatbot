# =====================================================================
# LLM (Groq) — never commit real keys
# =====================================================================
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile   # verify against current Groq model list
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Account MUST have Zero Data Retention enabled (governance requirement).
GROQ_ZDR_CONFIRMED=true

# =====================================================================
# Embeddings (local, in-boundary — Phase 3)
# =====================================================================
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# =====================================================================
# Postgres — two roles
# =====================================================================
# Owner role: migrations & ingestion only. NOT used to run generated SQL.
DATABASE_URL=postgresql://chatbot_owner:owner_pw@localhost:5432/chatbot
# Read-only, MASKED role: used for ALL generated-query execution (invariant #8).
DATABASE_URL_READONLY=postgresql://chatbot_readonly:readonly_pw@localhost:5432/chatbot

# =====================================================================
# Infra
# =====================================================================
REDIS_URL=redis://localhost:6379/0

# =====================================================================
# Auth (OIDC)
# =====================================================================
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
# Dev-only escape hatch: when true, a non-prod HS256 secret is accepted so the
# stack can run without a real IdP. MUST be false in any deployed environment.
AUTH_DEV_MODE=true
AUTH_DEV_HS256_SECRET=dev-only-not-a-real-secret-change-me

# =====================================================================
# Misc
# =====================================================================
LOG_LEVEL=INFO
APP_ENV=local
